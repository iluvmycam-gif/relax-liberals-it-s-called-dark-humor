# server.js content (from assistant earlier)
server_js = r"""
// server.js
// Run: npm install express socket.io
// Start: node server.js
const express = require('express');
const http = require('http');
const { Server } = require('socket.io');
const crypto = require('crypto');

const app = express();
const server = http.createServer(app);
const io = new Server(server);

app.use(express.static('public'));

const PORT = process.env.PORT || 3000;

// In-memory games store (for demo). For production, persist/store properly.
const games = {};

// Utility: generate short game code
function genCode(len = 6) {
  const chars = 'ABCDEFGHJKMNPQRSTUVWXYZ23456789';
  let s = '';
  for (let i = 0; i < len; i++) s += chars[Math.floor(Math.random() * chars.length)];
  return s;
}

// Deterministic RNG from string seed: xfnv1a + mulberry32
function xfnv1a(str) {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < str.length; i++) {
    h ^= str.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  return () => {
    h >>>= 0;
    h += 0x6D2B79F5;
    let t = Math.imul(h ^ (h >>> 15), 1 | h);
    t ^= t + Math.imul(t ^ (t >>> 7), 61 | t);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
function seededShuffle(arr, seed) {
  const rnd = xfnv1a(seed);
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(rnd() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

// Create a new game
function createGame({ seed, isPublic, password, playerLimit }) {
  let code = genCode();
  while (games[code]) code = genCode();
  const g = {
    code,
    seed: seed || code,
    isPublic: !!isPublic,
    password: password || '',
    playerLimit: playerLimit && Number(playerLimit) > 0 ? Number(playerLimit) : 0,
    phase: 'lobby',
    players: {},
    playerOrder: [],
    cards: {
      promptDeckOriginal: [],
      playDeckOriginal: [],
      promptDeck: [],
      playDeck: [],
    },
    playedThisRound: [],
    czarId: null,
    votes: {},
    voteCounts: {},
    createdAt: Date.now(),
  };
  games[code] = g;
  return g;
}

io.on('connection', (socket) => {
  console.log('socket connected', socket.id);

  socket.on('create_game', (opts, ack) => {
    const g = createGame(opts);
    if (Array.isArray(opts.promptDeckOriginal) && opts.promptDeckOriginal.length)
      g.cards.promptDeckOriginal = opts.promptDeckOriginal.slice();
    if (Array.isArray(opts.playDeckOriginal) && opts.playDeckOriginal.length)
      g.cards.playDeckOriginal = opts.playDeckOriginal.slice();

    g.cards.promptDeck = seededShuffle(g.cards.promptDeckOriginal, g.seed + '-prompts');
    g.cards.playDeck = seededShuffle(g.cards.playDeckOriginal, g.seed + '-plays');

    const player = {
      id: socket.id,
      name: opts.name || 'Host',
      hand: [],
      collected: [],
      isHost: true,
      connected: true,
    };
    g.players[socket.id] = player;
    g.playerOrder.push(socket.id);
    socket.join(g.code);
    socket.data.gameCode = g.code;
    socket.data.playerId = socket.id;

    ack({ ok: true, game: summarizeGame(g), code: g.code, seed: g.seed });
    io.to(g.code).emit('lobby_update', summarizeGame(g));
  });

  socket.on('join_game', (opts, ack) => {
    const code = (opts.code || '').toUpperCase();
    const g = games[code];
    if (!g) {
      return ack({ ok: false, error: 'Game not found' });
    }
    if (!g.isPublic) {
      if (!opts.password || opts.password !== g.password) {
        return ack({ ok: false, error: 'Incorrect password' });
      }
    }
    if (g.playerLimit > 0 && g.playerOrder.length >= g.playerLimit) {
      return ack({ ok: false, error: 'Game is full' });
    }
    const player = {
      id: socket.id,
      name: opts.name || 'Player',
      hand: [],
      collected: [],
      isHost: false,
      connected: true,
    };
    g.players[socket.id] = player;
    g.playerOrder.push(socket.id);
    socket.join(g.code);
    socket.data.gameCode = g.code;
    socket.data.playerId = socket.id;
    ack({ ok: true, game: summarizeGame(g), code: g.code, seed: g.seed });
    io.to(g.code).emit('lobby_update', summarizeGame(g));
  });

  socket.on('set_seed', (newSeed, ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g) return ack && ack({ ok: false, error: 'Game not found' });
    const p = g.players[socket.id];
    if (!p || !p.isHost) return ack && ack({ ok: false, error: 'Only host can change seed' });
    if (g.phase !== 'lobby') return ack && ack({ ok: false, error: 'Can only change seed in lobby' });
    g.seed = String(newSeed || genCode());
    g.cards.promptDeck = seededShuffle(g.cards.promptDeckOriginal, g.seed + '-prompts');
    g.cards.playDeck = seededShuffle(g.cards.playDeckOriginal, g.seed + '-plays');
    ack({ ok: true, seed: g.seed });
    io.to(g.code).emit('lobby_update', summarizeGame(g));
  });

  socket.on('set_visibility', (opts, ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    const p = g.players[socket.id];
    if (!p || !p.isHost) return ack && ack({ ok: false, error: 'Only host' });
    g.isPublic = !!opts.isPublic;
    g.password = opts.password || '';
    g.playerLimit = opts.playerLimit && Number(opts.playerLimit) > 0 ? Number(opts.playerLimit) : 0;
    ack({ ok: true });
    io.to(g.code).emit('lobby_update', summarizeGame(g));
  });

  socket.on('start_game', (opts, ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g) return ack && ack({ ok: false, error: 'Game not found' });
    if (g.playerOrder.length < 2) {
      return ack && ack({ ok: false, error: 'Need at least 2 players to start' });
    }
    if (g.phase !== 'lobby') return ack && ack({ ok: false, error: 'Game already started' });

    if (Array.isArray(opts.promptDeckOriginal) && opts.promptDeckOriginal.length) {
      g.cards.promptDeckOriginal = opts.promptDeckOriginal.slice();
    }
    if (Array.isArray(opts.playDeckOriginal) && opts.playDeckOriginal.length) {
      g.cards.playDeckOriginal = opts.playDeckOriginal.slice();
    }
    g.cards.promptDeck = seededShuffle(g.cards.promptDeckOriginal, g.seed + '-prompts');
    g.cards.playDeck = seededShuffle(g.cards.playDeckOriginal, g.seed + '-plays');

    g.phase = 'flashing';
    io.to(g.code).emit('phase_change', { phase: 'flashing' });
    ack && ack({ ok: true });
  });

  socket.on('start_voting_phase', (ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g || g.phase !== 'flashing') return ack && ack({ ok: false, error: 'Wrong phase' });

    g.votes = {};
    g.voteCounts = {};
    g.phase = 'voting';
    io.to(g.code).emit('phase_change', { phase: 'voting', players: publicPlayersList(g) });
    ack && ack({ ok: true });
  });

  socket.on('cast_vote_for_czar', (targetId, ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g || g.phase !== 'voting') return ack && ack({ ok: false, error: 'Not in voting phase' });
    if (!g.players[socket.id]) return ack && ack({ ok: false, error: 'Not a player' });
    if (g.votes[socket.id] === targetId) {
      delete g.votes[socket.id];
    } else {
      g.votes[socket.id] = targetId;
    }
    const counts = {};
    for (const v of Object.values(g.votes || {})) {
      if (!v) continue;
      counts[v] = (counts[v] || 0) + 1;
    }
    g.voteCounts = counts;
    io.to(g.code).emit('voting_update', { votes: g.votes, counts });
    const totalPlayers = g.playerOrder.length;
    const votesCast = Object.keys(g.votes).length;
    if (votesCast >= totalPlayers) {
      const max = Math.max(...Object.values(counts || {0:0}), 0);
      const winners = Object.keys(counts || {}).filter(k => counts[k] === max);
      if (winners.length === 1) {
        g.czarId = winners[0];
        g.phase = 'play';
        for (const pid of g.playerOrder) {
          const pl = g.players[pid];
          if (!pl) continue;
          pl.hand = pl.hand || [];
          if (pid === g.czarId) {
            pl.hand = pl.hand || [];
            continue;
          }
          while (pl.hand.length < 5) {
            if (g.cards.playDeck.length === 0) {
              g.cards.playDeck = seededShuffle(g.cards.playDeckOriginal, g.seed + '-plays-' + Date.now());
            }
            pl.hand.push(g.cards.playDeck.pop());
          }
        }
        if (g.cards.promptDeck.length === 0) {
          g.cards.promptDeck = seededShuffle(g.cards.promptDeckOriginal, g.seed + '-prompts-' + Date.now());
        }
        const thisPrompt = g.cards.promptDeck.pop();
        g.currentPrompt = thisPrompt;
        g.playedThisRound = [];
        for (const pid of g.playerOrder) {
          const pl = g.players[pid];
          if (!pl) continue;
          io.to(pid).emit('game_started_round', {
            phase: 'play',
            czarId: g.czarId,
            prompt: g.currentPrompt,
            hand: pl.hand,
            players: publicPlayersList(g),
          });
        }
        io.to(g.code).emit('phase_change', { phase: 'play', czarId: g.czarId, prompt: g.currentPrompt });
        ack && ack({ ok: true, czarId: g.czarId });
      } else {
        g.phase = 'voting_tiebreak';
        io.to(g.code).emit('voting_tiebreak', { tied: winners.map(id => ({ id, name: g.players[id].name })) });
        ack && ack({ ok: true, tiebreak: winners });
      }
    } else {
      ack && ack({ ok: true });
    }
  });

  socket.on('tiebreak_vote', (targetId, ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g || (g.phase !== 'voting_tiebreak' && g.phase !== 'voting')) return ack && ack({ ok: false, error: 'Wrong phase' });
    if (g.votes[socket.id] === targetId) delete g.votes[socket.id];
    else g.votes[socket.id] = targetId;
    const counts = {};
    const tiedSet = new Set(Object.keys(g.voteCounts || {}));
    for (const [voter, chosen] of Object.entries(g.votes || {})) {
      if (!chosen) continue;
      if (tiedSet.has(chosen)) {
        counts[chosen] = (counts[chosen] || 0) + 1;
      }
    }
    g.voteCounts = counts;
    io.to(g.code).emit('voting_update', { votes: g.votes, counts });

    const votesCast = Object.keys(g.votes).length;
    if (votesCast >= g.playerOrder.length) {
      const max = Math.max(...Object.values(counts || {0:0}), 0);
      const winners = Object.keys(counts || {}).filter(k => counts[k] === max);
      if (winners.length === 1) {
        g.czarId = winners[0];
        g.phase = 'play';
        for (const pid of g.playerOrder) {
          const pl = g.players[pid];
          if (!pl) continue;
          pl.hand = pl.hand || [];
          if (pid === g.czarId) {
            pl.hand = pl.hand || [];
            continue;
          }
          while (pl.hand.length < 5) {
            if (g.cards.playDeck.length === 0) {
              g.cards.playDeck = seededShuffle(g.cards.playDeckOriginal, g.seed + '-plays-' + Date.now());
            }
            pl.hand.push(g.cards.playDeck.pop());
          }
        }
        if (g.cards.promptDeck.length === 0) {
          g.cards.promptDeck = seededShuffle(g.cards.promptDeckOriginal, g.seed + '-prompts-' + Date.now());
        }
        const thisPrompt = g.cards.promptDeck.pop();
        g.currentPrompt = thisPrompt;
        g.playedThisRound = [];
        for (const pid of g.playerOrder) {
          const pl = g.players[pid];
          if (!pl) continue;
          io.to(pid).emit('game_started_round', {
            phase: 'play',
            czarId: g.czarId,
            prompt: g.currentPrompt,
            hand: pl.hand,
            players: publicPlayersList(g),
          });
        }
        io.to(g.code).emit('phase_change', { phase: 'play', czarId: g.czarId, prompt: g.currentPrompt });
        ack && ack({ ok: true, czarId: g.czarId });
      } else {
        g.votes = {};
        io.to(g.code).emit('voting_tiebreak', { tied: winners.map(id => ({ id, name: g.players[id].name })) });
        ack && ack({ ok: true, tiebreak: winners });
      }
    } else {
      ack && ack({ ok: true });
    }
  });

  socket.on('play_card', (cardIndex, ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g || g.phase !== 'play') return ack && ack({ ok: false, error: 'Not in play phase' });
    if (!g.players[socket.id]) return ack && ack({ ok: false, error: 'Not a player' });
    if (socket.id === g.czarId) return ack && ack({ ok: false, error: 'Czar cannot play' });
    const player = g.players[socket.id];
    if (!player.hand[cardIndex]) return ack && ack({ ok: false, error: 'Invalid card' });

    const cardText = player.hand.splice(cardIndex, 1)[0];
    g.playedThisRound.push({ cardText, playerId: socket.id });
    if (g.cards.playDeck.length === 0) {
      g.cards.playDeck = seededShuffle(g.cards.playDeckOriginal, g.seed + '-plays-' + Date.now());
    }
    if (g.cards.playDeck.length > 0) {
      player.hand.push(g.cards.playDeck.pop());
    }
    io.to(socket.id).emit('hand_update', player.hand);
    const nonCzarCount = g.playerOrder.filter(pid => pid !== g.czarId).length;
    if (g.playedThisRound.length >= nonCzarCount) {
      g.anonymizedRound = seededShuffle(g.playedThisRound.map((p) => p.cardText), g.seed + '-anon-' + Date.now());
      const copy = g.playedThisRound.slice();
      g.anonymizedMap = g.anonymizedRound.map((cardText) => {
        const i = copy.findIndex(c => c.cardText === cardText);
        if (i === -1) {
          const fallback = copy.pop();
          return fallback;
        } else {
          const found = copy.splice(i,1)[0];
          return found;
        }
      });
      io.to(g.czarId).emit('cards_ready_for_czar', { cards: g.anonymizedRound });
      io.to(g.code).emit('round_all_sent', { count: g.anonymizedRound.length });
    } else {
      io.to(g.code).emit('play_progress', { played: g.playedThisRound.length, needed: nonCzarCount });
    }
    ack && ack({ ok: true });
  });

  socket.on('reveal_next_card', (ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g || g.phase !== 'play') return ack && ack({ ok: false, error: 'Not in play phase' });
    if (socket.id !== g.czarId) return ack && ack({ ok: false, error: 'Only czar can reveal' });
    if (!g.anonymizedRound || g.anonymizedRound.length === 0) return ack && ack({ ok: false, error: 'No cards to reveal' });
    const revealedCard = g.anonymizedRound.shift();
    g.revealedThisRound = g.revealedThisRound || [];
    g.revealedThisRound.push(revealedCard);
    io.to(g.czarId).emit('card_revealed', { cardText: revealedCard, revealedIndex: g.revealedThisRound.length - 1 });
    io.to(g.code).emit('card_revealed_public', { cardText: revealedCard, revealedIndex: g.revealedThisRound.length - 1 });
    ack && ack({ ok: true, revealed: revealedCard });

    if (g.anonymizedRound.length === 0) {
      io.to(g.czarId).emit('ready_to_choose', { revealed: g.revealedThisRound });
    }
  });

  socket.on('czar_select', (revealedIndex, ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g || g.phase !== 'play') return ack && ack({ ok: false, error: 'Not in play phase' });
    if (socket.id !== g.czarId) return ack && ack({ ok: false, error: 'Only czar can select' });
    if (!g.revealedThisRound || revealedIndex < 0 || revealedIndex >= g.revealedThisRound.length) {
      return ack && ack({ ok: false, error: 'Invalid selection' });
    }
    g.czarSelection = revealedIndex;
    io.to(g.czarId).emit('czar_selection_made', { selectedIndex: revealedIndex });
    ack && ack({ ok: true });
  });

  socket.on('czar_confirm', (ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g || g.phase !== 'play') return ack && ack({ ok: false, error: 'Not in play phase' });
    if (socket.id !== g.czarId) return ack && ack({ ok: false, error: 'Only czar can confirm' });
    if (typeof g.czarSelection !== 'number') return ack && ack({ ok: false, error: 'No selection made' });
    const selectedCardText = g.revealedThisRound[g.czarSelection];
    let winnerPlayerId = null;
    if (g.playedThisRound && g.playedThisRound.length) {
      g.awardedThisRound = g.awardedThisRound || [];
      for (const entry of g.playedThisRound) {
        if (entry.cardText === selectedCardText && !g.awardedThisRound.includes(entry)) {
          winnerPlayerId = entry.playerId;
          g.awardedThisRound.push(entry);
          break;
        }
      }
    }
    if (!winnerPlayerId) {
      winnerPlayerId = (g.playedThisRound && g.playedThisRound[0] && g.playedThisRound[0].playerId) || null;
    }

    if (!g.players[winnerPlayerId]) {
      return ack && ack({ ok: false, error: 'Winner player not found' });
    }
    g.players[winnerPlayerId].collected.push(g.currentPrompt);
    io.to(g.code).emit('round_result', {
      winner: { id: winnerPlayerId, name: g.players[winnerPlayerId].name },
      winningCard: selectedCardText,
      prompt: g.currentPrompt,
    });

    g.czarId = winnerPlayerId;
    g.playedThisRound = [];
    g.anonymizedRound = [];
    g.anonymizedMap = [];
    g.revealedThisRound = [];
    g.czarSelection = null;
    g.awardedThisRound = [];

    if (g.cards.promptDeck.length === 0) {
      g.cards.promptDeck = seededShuffle(g.cards.promptDeckOriginal, g.seed + '-prompts-' + Date.now());
    }
    const thisPrompt = g.cards.promptDeck.pop();
    g.currentPrompt = thisPrompt;

    for (const pid of g.playerOrder) {
      const pl = g.players[pid];
      if (!pl) continue;
      if (pid === g.czarId) continue;
      while (pl.hand.length < 5) {
        if (g.cards.playDeck.length === 0) {
          g.cards.playDeck = seededShuffle(g.cards.playDeckOriginal, g.seed + '-plays-' + Date.now());
        }
        if (g.cards.playDeck.length === 0) break;
        pl.hand.push(g.cards.playDeck.pop());
      }
      io.to(pid).emit('hand_update', pl.hand);
    }

    for (const pid of g.playerOrder) {
      const pl = g.players[pid];
      if (!pl) continue;
      io.to(pid).emit('new_round', {
        czarId: g.czarId,
        prompt: g.currentPrompt,
        hand: pl.hand,
        players: publicPlayersList(g),
      });
    }
    io.to(g.code).emit('phase_change', { phase: 'play', czarId: g.czarId, prompt: g.currentPrompt });

    ack && ack({ ok: true });
  });

  socket.on('end_game_request', (ack) => {
    ack && ack({ ok: true });
  });

  socket.on('end_game_confirm', (confirm, ack) => {
    const code = socket.data.gameCode;
    if (!code) return ack && ack({ ok: false, error: 'Not in a game' });
    const g = games[code];
    if (!g) return ack && ack({ ok: false, error: 'Game not found' });
    if (!confirm) return ack && ack({ ok: true, ended: false });
    const leaderboard = Object.values(g.players).map(p => ({ id: p.id, name: p.name, collected: p.collected.length }));
    leaderboard.sort((a,b) => b.collected - a.collected);
    io.to(g.code).emit('game_ended', { leaderboard });
    delete games[code];
    ack && ack({ ok: true, ended: true });
  });

  socket.on('disconnect', () => {
    const code = socket.data.gameCode;
    if (!code) return;
    const g = games[code];
    if (!g) return;
    const p = g.players[socket.id];
    if (p) {
      p.connected = false;
      g.playerOrder = g.playerOrder.filter(x => x !== socket.id);
      delete g.players[socket.id];
      if (g.playerOrder.length === 0) {
        delete games[code];
      } else {
        io.to(g.code).emit('lobby_update', summarizeGame(g));
      }
    }
    console.log('socket disconnected', socket.id);
  });
});

function publicPlayersList(g) {
  return g.playerOrder.map(pid => {
    const p = g.players[pid];
    return { id: pid, name: p ? p.name : 'Unknown', collected: p ? p.collected.length : 0 };
  });
}
function summarizeGame(g) {
  return {
    code: g.code,
    seed: g.seed,
    isPublic: g.isPublic,
    playerLimit: g.playerLimit,
    phase: g.phase,
    players: publicPlayersList(g),
  };
}

server.listen(PORT, () => {
  console.log(`Server listening on http://localhost:${PORT}`);
});
"""

