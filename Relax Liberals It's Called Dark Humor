const FLASH_WORDS = ["Whoever is willing to say penis the loudest gets to be the card czar"];

const socket = io();
let myHand = [], selectedHandIndex = null, selectedRevealedIndex = null, selectedVoteTarget = null;
let currentGame=null,mySocketId=null,currentCzarId=null;

const nameInput=document.getElementById('nameInput');
const newGameBtn=document.getElementById('newGameBtn');
const joinGameBtn=document.getElementById('joinGameBtn');
const endGameBtn=document.getElementById('endGameBtn');
const lobbyPanel=document.getElementById('lobbyPanel');
const gamePanel=document.getElementById('gamePanel');
const playersList=document.getElementById('playersList');
const gameCodeDisplay=document.getElementById('gameCodeDisplay');
const seedDisplay=document.getElementById('seedDisplay');
const startGameBtn=document.getElementById('startGameBtn');
const seedInput=document.getElementById('seedInput');
const applySeedBtn=document.getElementById('applySeedBtn');
const flashArea=document.getElementById('flashArea');
const flashText=document.getElementById('flashText');
const voteArea=document.getElementById('voteArea');
const votePlayers=document.getElementById('votePlayers');
const castVoteBtn=document.getElementById('castVoteBtn');
const promptBox=document.getElementById('promptBox');
const promptText=document.getElementById('promptText');
const handArea=document.getElementById('handArea');
const handCards=document.getElementById('handCards');
const sendCardBtn=document.getElementById('sendCardBtn');
const czarArea=document.getElementById('czarArea');
const revealNextBtn=document.getElementById('revealNextBtn');
const confirmPickBtn=document.getElementById('confirmPickBtn');
const revealedCards=document.getElementById('revealedCards');
const phaseArea=document.getElementById('phaseArea');
const gameCodeHeader=document.getElementById('gameCodeHeader');
const collectedCounts=document.getElementById('collectedCounts');
const endModal=document.getElementById('endModal');
const endYes=document.getElementById('endYes');
const endNo=document.getElementById('endNo');
const resultModal=document.getElementById('resultModal');
const leaderboardList=document.getElementById('leaderboardList');

newGameBtn.addEventListener('click',()=>{
  const name=nameInput.value||'Host';
  socket.emit('create_game',{name,seed:'',isPublic:true,password:'',playerLimit:0,promptDeckOriginal:PROMPT_CARDS,playDeckOriginal:PLAYING_CARDS},(res)=>{ if(res.ok){ mySocketId=socket.id; currentGame=res.game; showLobby(res.code,res.seed,res.game.players); } else alert(res.error||'Error creating'); });
});

joinGameBtn.addEventListener('click',()=>{
  const code=prompt('Enter Game Code:'); if(!code) return;
  const name=nameInput.value||'Player';
  const password=prompt('Password if private:')||'';
  socket.emit('join_game',{code,name,password},(res)=>{ if(res.ok){ mySocketId=socket.id; currentGame=res.game; showLobby(res.code,res.seed,res.game.players); } else alert(res.error||'Error joining'); });
});

function showLobby(code,seed,players){ lobbyPanel.style.display='block'; gamePanel.style.display='none'; gameCodeDisplay.textContent=code; seedDisplay.textContent=seed; renderPlayers(players); }
function renderPlayers(players){ playersList.innerHTML=''; players.forEach(p=>{ const el=document.createElement('div'); el.className='player'; el.innerHTML=`<div>${p.name}</div><div class="tiny">${p.collected||0}</div>`; playersList.appendChild(el); }); }

applySeedBtn.addEventListener('click',()=>{ const s=seedInput.value.trim(); if(!s) return alert('Enter a seed'); socket.emit('set_seed',s,(res)=>{ if(res.ok){ seedDisplay.textContent=res.seed; alert('Seed updated: '+res.seed); } else alert(res.error||'Unable to set seed'); }); });

startGameBtn.addEventListener('click',()=>{ socket.emit('start_game',{promptDeckOriginal:PROMPT_CARDS,playDeckOriginal:PLAYING_CARDS},(res)=>{ if(!res.ok) alert(res.error||'Cannot start'); }); });

castVoteBtn.addEventListener('click',()=>{ if(!selectedVoteTarget) return alert('Select a player to vote for first'); socket.emit('cast_vote_for_czar',selectedVoteTarget,(res)=>{ if(!res.ok) alert(res.error||'Vote failed'); }); });

endGameBtn.addEventListener('click',()=>{ endModal.style.display='flex'; });
endNo.addEventListener('click',()=>{ endModal.style.display='none'; });
endYes.addEventListener('click',()=>{ socket.emit('end_game_confirm',true,(res)=>{ endModal.style.display='none'; if(!res.ok) alert(res.error||'Unable to end'); }); });

sendCardBtn.addEventListener('click',()=>{ if(selectedHandIndex===null) return alert('Select a card first'); socket.emit('play_card',selectedHandIndex,(res)=>{ if(!res.ok) alert(res.error||'Play failed'); else{ selectedHandIndex=null; renderHand(myHand); } }); });

revealNextBtn.addEventListener('click',()=>{ socket.emit('reveal_next_card',(res)=>{ if(!res.ok) console.warn(res.error); }); });

confirmPickBtn.addEventListener('click',()=>{ if(selectedRevealedIndex===null) return alert('Select a revealed card first'); socket.emit('czar_select',selectedRevealedIndex,(res)=>{ if(!res.ok) return alert(res.error||'Select failed'); socket.emit('czar_confirm',(r2)=>{ if(!r2.ok) return alert(r2.error||'Confirm failed'); selectedRevealedIndex=null; confirmPickBtn.disabled=true; revealedCards.innerHTML=''; }); }); });

function renderVotePlayers(players){ votePlayers.innerHTML=''; players.forEach(p=>{ const el=document.createElement('div'); el.className='player'; el.dataset.id=p.id; el.innerHTML=`<div>${p.name}</div><div class="tiny">${p.collected||0}</div>`; el.addEventListener('click',()=>{ if(selectedVoteTarget===p.id){ selectedVoteTarget=null; el.style.outline=''; } else{ selectedVoteTarget=p.id; votePlayers.querySelectorAll('.player').forEach(x=>x.style.outline=''); el.style.outline='2px solid #8b5cf6'; } }); votePlayers.appendChild(el); }); }

function renderHand(hand){ myHand=(hand||[]).slice(); handCards.innerHTML=''; myHand.forEach((c,i)=>{ const div=document.createElement('div'); div.className='card'; div.textContent=c; div.dataset.index=i; if(i===selectedHandIndex) div.classList.add('selected'); div.addEventListener('click',()=>{ selectedHandIndex = selectedHandIndex===i ? null : i; renderHand(myHand); }); handCards.appendChild(div); }); }

function renderPlayersPanel(players){ playersList.innerHTML=''; players.forEach(p=>{ const el=document.createElement('div'); el.className='player'; el.innerHTML=`<div>${p.name}</div><div class="tiny">Collected: ${p.collected||0}</div>`; playersList.appendChild(el); }); }

socket.on('connect',()=>{ document.getElementById('connectedStatus').textContent='Connected'; });

socket.on('lobby_update',(game)=>{ currentGame=game; gameCodeDisplay.textContent=game.code; seedDisplay.textContent=game.seed; renderPlayersPanel(game.players); gamePanel.style.display='none'; lobbyPanel.style.display='block'; });

socket.on('phase_change',(data)=>{ phaseArea.textContent='Phase: '+data.phase;
  if(data.phase==='flashing'){ lobbyPanel.style.display='none'; gamePanel.style.display='block'; flashArea.style.display='block'; flashText.textContent = FLASH_WORDS.join(' '); socket.emit('start_voting_phase',()=>{}); }
  else if(data.phase==='voting'){ voteArea.style.display='block'; handArea.style.display='none'; czarArea.style.display='none'; renderVotePlayers(data.players||currentGame.players); flashArea.style.display='block'; }
  else if(data.phase==='play'){ voteArea.style.display='none'; flashArea.style.display='none'; }
});

socket.on('voting_update',(data)=>{});
socket.on('voting_tiebreak',(data)=>{ alert('Tie! Revote among: '+data.tied.map(x=>x.name).join(', ')); });

socket.on('game_started_round',(data)=>{ currentCzarId=data.czarId; myHand=data.hand||[]; renderHand(myHand); promptBox.style.display='block'; promptText.textContent=data.prompt; gameCodeHeader.textContent=currentGame.code; if(socket.id===currentCzarId){ czarArea.style.display='block'; handArea.style.display='none'; } else { czarArea.style.display='none'; handArea.style.display='block'; } voteArea.style.display='none'; });

socket.on('hand_update',(hand)=>{ myHand=hand||[]; renderHand(myHand); });
socket.on('play_progress',(data)=>{ phaseArea.textContent=`Waiting for players: ${data.played}/${data.needed}`; });
socket.on('round_all_sent',(data)=>{ phaseArea.textContent='All cards sent. Waiting for czar to reveal...'; });

socket.on('cards_ready_for_czar',(data)=>{ revealedCards.innerHTML=''; data.cards.forEach((c,idx)=>{ const el=document.createElement('div'); el.className='card'; el.textContent='Face Down'; el.dataset.index=idx; el.addEventListener('click',()=>{ const rIdx=Number(el.dataset.index); if(!el.dataset.revealed) return; if(selectedRevealedIndex===rIdx){ selectedRevealedIndex=null; el.style.outline=''; confirmPickBtn.disabled=true; } else { revealedCards.querySelectorAll('.card').forEach(x=>x.style.outline=''); selectedRevealedIndex=rIdx; el.style.outline='2px solid #34d399'; confirmPickBtn.disabled=false; } }); revealedCards.appendChild(el); }); czarArea.style.display='block'; handArea.style.display='none'; phaseArea.textContent='Czar: reveal cards one by one'; });

socket.on('card_revealed',(data)=>{ const cardElems=revealedCards.querySelectorAll('.card'); const el=cardElems[data.revealedIndex]; if(el){ el.textContent=data.cardText; el.dataset.revealed='1'; }});
socket.on('card_revealed_public',(data)=>{ const cardElems=revealedCards.querySelectorAll('.card'); const el=cardElems[data.revealedIndex]; if(el){ el.textContent=data.cardText; el.dataset.revealed='1'; }});

socket.on('ready_to_choose',(data)=>{ phaseArea.textContent='All cards revealed. Czar pick the best and Confirm.'; confirmPickBtn.disabled=true; });
socket.on('round_result',(data)=>{ alert(`Round winner: ${data.winner.name}\nWinning card: ${data.winningCard}`); });
socket.on('new_round',(data)=>{ currentCzarId=data.czarId; promptText.textContent=data.prompt; myHand=data.hand||[]; renderHand(myHand); revealedCards.innerHTML=''; confirmPickBtn.disabled=true; if(socket.id===currentCzarId){ czarArea.style.display='block'; handArea.style.display='none'; } else { czarArea.style.display='none'; handArea.style.display='block'; } });

socket.on('game_ended',(data)=>{ resultModal.style.display='flex'; leaderboardList.innerHTML=''; data.leaderboard.forEach((r,idx)=>{ const d=document.createElement('div'); d.innerHTML=`${idx+1}. ${r.name} — ${r.collected} prompt cards`; leaderboardList.appendChild(d); }); });

document.getElementById('closeResult').addEventListener('click',()=>{ resultModal.style.display='none'; location.reload(); });
</script>
</body>
</html>
