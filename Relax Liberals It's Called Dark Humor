<div id="handArea" style="display:none;"><div class="tiny">Your hand</div><div id="handCards" class="hand"></div><button id="sendCardBtn">Send Selected</button></div>

<div id="czarArea" style="display:none;"><div><button id="revealNextBtn">Reveal Next Card</button><button id="confirmPickBtn" disabled>Confirm Pick</button></div><div id="revealedCards" style="display:flex;gap:8px;flex-wrap:wrap;"></div></div>

<div id="voteArea" style="display:none;"><div class="tiny">Vote for initial Card Czar</div><div id="votePlayers"></div><button id="castVoteBtn">Vote</button></div>

<div id="flashArea" style="margin-top:12px;display:none;"><div id="flashText" style="font-size:20px;font-weight:700;" class="center"></div></div>

