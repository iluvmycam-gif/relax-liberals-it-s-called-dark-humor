    players: [],
    playingDeck: [...SAFE_PLAYING_CARDS],
    promptDeck: [...SAFE_PROMPT_CARDS],
    usedPlaying: [],
    usedPrompts: [],
    round: 0,
    czarId: null,
    submissions: [], // {playerId, cardText}
    votes: {}, // playerId -> votedPlayerId
    scores: {}, // playerId -> number
    createdAt: Date.now(),
  };
  shuffleWithRng(game.playingDeck, mulberry32(hashStringToInt(seedKey)));
  shuffleWithRng(game.promptDeck, mulberry32(hashStringToInt(seedKey+':prompts')));
  saveGameObj(seedKey, game);
  // add host as player
  const player = { id: id(), name, hand: [], score:0, isHost:true };
  game.players.push(player);
  saveGameObj(seedKey, game);
  enterGame(seedKey, player.id);
};

joinGameBtn.onclick = ()=> {
  const seed = joinSeed.value.trim();
  if(!seed){ alert('Enter seed to join'); return; }
  const game = loadGameObj(seed);
  if(!game){ alert('No game with that seed in this browser'); return; }
  if(game.password){
    if(!joinPassword.value){ alert('This game requires a password'); return; }
    if(btoa(joinPassword.value) !== game.password){ alert('Wrong password'); return; }
  }
  if(game.limit && game.players.length >= game.limit){ alert('Player limit reached'); return; }
  const player={ id:id(), name: joinName.value.trim() || 'Guest', hand:[], score:0, isHost:false };
  game.players.push(player);
  saveGameObj(seed, game);
  enterGame(seed, player.id);
};

// enter lobby
function enterGame(seed, myPlayerId){
  const game = loadGameObj(seed);
  if(!game) return alert('Could not load game');
  App.game = game;
  App.activePlayerId = myPlayerId;
  // save active player in localStorage so other tabs could potentially pick it up (not implemented)
  showLobby();
}

function showLobby(){
  const g = App.game; if(!g) return;
  screenStart.classList.add('hidden');
  screenLobby.classList.remove('hidden');
  displaySeed.textContent = g.seed;
  refreshPlayersUI();
  rebuildActivePlayerSelect();
  rebuildVoteList();
  updateGameUI();
}

// refresh players column
function refreshPlayersUI(){
  const g = App.game; playersList.innerHTML=''; leaderboard.innerHTML='';
  g.players.forEach(p=>{
    const el = document.createElement('div'); el.className='player-item';
    el.innerHTML = `<div><strong>${p.name}</strong><div class="meta">Score: ${p.score||0} ${p.id===g.hostId?'<span class="muted"> (host)</span>':''}</div></div>
    <div style="min-width:60px"><span class="muted small">${p.id===g.czarId? 'Czar':''}</span></div>`;
    playersList.appendChild(el);
  });
  // leaderboard
  const sorted = [...g.players].sort((a,b)=> (b.score||0)-(a.score||0));
  leaderboard.innerHTML = sorted.map(p=>`<div class="player-item"><div><strong>${p.name}</strong><div class="meta">Points: ${p.score||0}</div></div></div>`).join('');
}

// active player dropdown
function rebuildActivePlayerSelect(){
  const g=App.game; activePlayerSelect.innerHTML='';
  g.players.forEach(p=>{
    const opt = document.createElement('option'); opt.value=p.id; opt.textContent=p.name; activePlayerSelect.appendChild(opt);
  });
  if(!g.players.find(x=>x.id===App.activePlayerId)) App.activePlayerId = g.players[0].id;
  activePlayerSelect.value = App.activePlayerId;
  activePlayerSelect.onchange = ()=> { App.activePlayerId = activePlayerSelect.value; refreshPlayersUI(); renderHand(); renderSubmissionStack(); updateVoteUI(); }
  renderHand(); renderSubmissionStack();
}

// Voting UI
let lastVoteSelections = {}; // active player -> selected player id
function rebuildVoteList(){
  const g=App.game; voteNames.innerHTML='';
  g.players.forEach(p=>{
    const div = document.createElement('div'); div.className='player-item'; div.dataset.id=p.id;
    div.innerHTML = `<div><strong>${p.name}</strong></div><div class="meta">click to select</div>`;
    div.onclick = ()=> {
      // toggle selection for current active player view (not final cast)
      const current = lastVoteSelections[App.activePlayerId];
      if(current === p.id) delete lastVoteSelections[App.activePlayerId];
      else lastVoteSelections[App.activePlayerId] = p.id;
      updateVoteUI();
    }
    voteNames.appendChild(div);
  });
  updateVoteUI();
}
function updateVoteUI(){
  const items = voteNames.querySelectorAll('.player-item');
  items.forEach(it=>{
    const pid = it.dataset.id;
    const selected = lastVoteSelections[App.activePlayerId] === pid;
    it.style.outline = selected ? '2px solid rgba(159,122,234,0.25)' : 'none';
  });
  // votes cast summary
  const g=App.game;
  const totalVotes = Object.keys(g.votes||{}).length;
  voteStatus.textContent = `Votes cast: ${totalVotes}/${g.players.length} (cast by each player using "Vote").`;
}

// cast vote button (active player casts their vote)
castVoteBtn.onclick = ()=>{
  const g=App.game;
  const selection = lastVoteSelections[App.activePlayerId];
  if(!selection){ alert('Select someone (click their name) to vote for them'); return; }
  g.votes[App.activePlayerId] = selection;
  saveGameObj(g.seed, g);
  App.game = g;
  rebuildVoteList(); updateVoteUI(); refreshPlayersUI();
  // if everyone voted, tally
  if(Object.keys(g.votes).length >= g.players.length){
    tallyVotes();
  } else {
    alert('Vote recorded. Switch active player for the next person to vote (simulate).');
  }
}

// tally votes and handle ties
function tallyVotes(){
  const g=App.game;
  const counts = {};
  Object.values(g.votes).forEach(v=>counts[v]=(counts[v]||0)+1);
  let max = 0; for(const k in counts) if(counts[k]>max) max=counts[k];
  const winners = Object.keys(counts).filter(k=>counts[k]===max);
  if(winners.length===1){
    g.czarId = winners[0];
    g.votes = {};
    saveGameObj(g.seed,g); App.game=g;
    refreshPlayersUI();
    alert('First card czar selected: '+(g.players.find(p=>p.id===g.czarId).name));
    startRoundBtn.classList.remove('hidden');
  } else {
    // tie: reset votes and restrict choices to tied players
    g.votes = {};
    saveGameObj(g.seed,g); App.game=g;
    alert('Tie detected — revote among tied players only. Click the names of the tied players to vote again.');
    // visually restrict vote list to winners
    voteNames.childNodes.forEach(n=>{
      const pid = n.dataset.id;
      n.style.display = winners.includes(pid) ? '' : 'none';
    });
  }
}

// Start round: deal hands and pick prompt
startRoundBtn.onclick = ()=> {
  startRoundBtn.classList.add('hidden');
  dealInitialHands();
  nextPrompt();
  updateGameUI();
}

// dealing/replenish
function dealInitialHands(){
  const g=App.game;
  // ensure decks exist
  if(!g.playingDeck || g.playingDeck.length===0) g.playingDeck = [...SAFE_PLAYING_CARDS];
  if(!g.promptDeck || g.promptDeck.length===0) g.promptDeck = [...SAFE_PROMPT_CARDS];
  // shuffle with seed-based rng
  const rng = mulberry32(hashStringToInt(g.seed+':deal'+Math.random()));
  shuffleWithRng(g.playingDeck, rng);
  shuffleWithRng(g.promptDeck, rng);
  // give each non-czar 5 cards
  g.players.forEach(p=>{
    p.hand = p.hand || [];
    if(p.id === g.czarId){
      // czar gets no playing cards initially but will still maintain hand count of 5 by rules described (they get a pile but don't play)
      // we'll ensure czar has 5 as well to match user's request
    } else {
      while(p.hand.length < 5 && g.playingDeck.length){
        p.hand.push(g.playingDeck.pop());
      }
    }
  });
  saveGameObj(g.seed,g); App.game=g;
  refreshPlayersUI(); renderHand(); updateCounts();
}

function nextPrompt(){
  const g=App.game;
  if(!g.promptDeck || g.promptDeck.length===0){
    // recycle
    g.promptDeck = g.usedPrompts.splice(0);
  }
  if(g.promptDeck.length===0) { currentPrompt.textContent = 'No prompts left.'; return; }
  // draw top prompt
  const prompt = g.promptDeck.pop();
  g.currentPrompt = prompt;
  g.usedPrompts = g.usedPrompts || [];
  g.usedPrompts.push(prompt);
  // clear submissions
  g.submissions = [];
  saveGameObj(g.seed,g); App.game=g;
  currentPrompt.textContent = prompt;
  submissionStack.textContent = 'No submissions';
  revealBtn.classList.add('hidden'); czarConfirmBtn.classList.add('hidden');
  renderHand(); updateCounts();
}

// render hand for active player
let selectedHandIndex = null;
function renderHand(){
  const g=App.game; handArea.innerHTML='';
  const me = g.players.find(p=>p.id===App.activePlayerId);
  if(!me) return;
  me.hand = me.hand || [];
  me.hand.forEach((cardText, idx)=>{
    const el = document.createElement('div'); el.className='card'; el.textContent = cardText;
    if(selectedHandIndex===idx) el.classList.add('selected');
    el.onclick = ()=> {
      // toggle select if not czar and not already submitted
      if(g.czarId === me.id){ alert('Card Czar does not select a submission.'); return; }
      if(me._submitted) { alert('You already sent your card this round'); return; }
      selectedHandIndex = (selectedHandIndex===idx)? null : idx;
      renderHand();
    }
    handArea.appendChild(el);
  });
}

// send card button
sendCardBtn.onclick = ()=> {
  const g=App.game;
  const me = g.players.find(p=>p.id===App.activePlayerId);
  if(!me) return;
  if(g.czarId === me.id) { alert('Card Czar does not send cards'); return; }
  if(me._submitted) { alert('You already sent your card'); return; }
  if(selectedHandIndex===null){ alert('Select a card from your hand to send'); return; }
  const card = me.hand.splice(selectedHandIndex,1)[0];
  me._submitted = true;
  g.submissions.push({ playerId:me.id, cardText:card });
  // save and shuffle submission placeholder (we'll shuffle the pile when czar reveals)
  saveGameObj(g.seed,g); App.game=g;
  selectedHandIndex = null;
  renderHand(); renderSubmissionStack(); updateCounts();
  // check if all non-czars submitted
  const nonCzars = g.players.filter(p=>p.id!==g.czarId);
  if(g.submissions.length >= nonCzars.length){
    // submissions complete -> allow czar to reveal
    if(App.activePlayerId === g.czarId){
      revealBtn.classList.remove('hidden');
      alert('All submissions in — as Card Czar you may reveal them (tap the pile).');
    } else {
      alert('Card sent. Wait for Card Czar to reveal submissions.');
    }
  } else {
    alert('Card sent. Switch active player and have the next player send their card (simulate).');
  }
}

// render submission stack
let revealIndex = -1;
let shuffledSubmissions = [];
function renderSubmissionStack(){
  const g=App.game;
  if(!g.submissions || g.submissions.length===0) { submissionStack.textContent='No submissions'; return; }
  submissionStack.textContent = `${g.submissions.length} face-down card(s) — tap to reveal (Czar)`;
  // clicking stack for reveal only allowed to czar
  submissionStack.onclick = ()=>{
    if(App.activePlayerId !== g.czarId){ alert('Only Card Czar can reveal'); return; }
    // shuffle the submissions (random order)
    shuffledSubmissions = [...g.submissions];
    shuffleWithRng(shuffledSubmissions, mulberry32(hashStringToInt(g.seed+':submissions'+Date.now())));
    revealIndex = -1;
    revealBtn.classList.remove('hidden');
    czarConfirmBtn.classList.remove('hidden');
    alert('Submissions shuffled. Use Reveal Next to flip them one by one.');
  }
}

// reveal next
revealBtn.onclick = ()=>{
  if(!shuffledSubmissions || shuffledSubmissions.length===0){ alert('No submissions to reveal'); return; }
  revealIndex++;
  if(revealIndex >= shuffledSubmissions.length){ alert('All revealed'); return; }
  const card = shuffledSubmissions[revealIndex];
  // show revealed card
  submissionStack.innerHTML = `<div class="card selected">${card.cardText}</div>`;
  czarPickInfo.textContent = `Revealed ${revealIndex+1}/${shuffledSubmissions.length}. Click a revealed card to pick it as winner.`;
  // allow czar to click on the revealed card to select winner
  const revealedDiv = submissionStack.querySelector('.card');
  let czarPick = null;
  revealedDiv.onclick = ()=> {
    czarPick = card;
    // mark chosen visually
    revealedDiv.style.outline = '3px solid rgba(159,122,234,0.35)';
    czarConfirmBtn.onclick = ()=> {
      if(!czarPick) return alert('Select a revealed card as winner first.');
      // award point
      const winner = g.players.find(p=>p.id===czarPick.playerId);
      winner.score = (winner.score||0)+1;
      // winner becomes next czar
      g.czarId = winner.id;
      // winner receives the prompt card (we'll track via score already)
      // replenish hands: each non-czar should have 5 cards; add 1 to players that are not czar and currently <5
      g.players.forEach(p=>{
        if(p.id !== g.czarId){
          while(p.hand.length < 5 && g.playingDeck.length){
            p.hand.push(g.playingDeck.pop());
          }
        }
      });
      // record used prompt already handled; start next prompt
      saveGameObj(g.seed,g); App.game=g;
      refreshPlayersUI(); renderHand(); renderSubmissionStack();
      nextPrompt();
    }
  }
}

// czar confirm (if used separately) - kept for UX; actual confirm handled in reveal flow
czarConfirmBtn.onclick = ()=>{
  alert('To confirm a winner, click the revealed card and then press Confirm.');
}

// reshuffle button (force recycle decks)
reshuffleBtn.onclick = ()=>{
  const g=App.game;
  // recycle used into decks and shuffle
  g.playingDeck = (g.playingDeck || []).concat(g.usedPlaying || []);
  g.usedPlaying = [];
  g.promptDeck = (g.promptDeck || []).concat(g.usedPrompts || []);
  g.usedPrompts = [];
  shuffleWithRng(g.playingDeck, mulberry32(hashStringToInt(g.seed+':reshuffle'+Date.now())));
  shuffleWithRng(g.promptDeck, mulberry32(hashStringToInt(g.seed+':reshuffleP'+Date.now())));
  saveGameObj(g.seed,g); App.game=g; updateCounts(); alert('Decks reshuffled.');
}

// End game modal
endGameBtn.onclick = ()=> {
  showModal('Are you sure you want to end the game?', [
    {text:'Yes', cls:'danger', onClick: ()=> {
      const g = App.game;
      if(!g) return hideModal();
      // show leaderboard and remove game from storage
      const sorted = [...g.players].sort((a,b)=> (b.score||0)-(a.score||0));
      const msg = 'Final leaderboard:\\n' + sorted.map((p,i)=>`${i+1}. ${p.name} — ${p.score||0}`).join('\\n');
      alert(msg);
      removeGame(g.seed);
      App.game = null;
      hideModal();
      // go back to start
      screenLobby.classList.add('hidden');
      screenStart.classList.remove('hidden');
    }},
    {text:'No', onClick: hideModal}
  ]);
};

function showModal(message, buttons){
  modalRoot.innerHTML = `
    <div class="modal-backdrop">
      <div class="modal">
        <div style="margin-bottom:12px">${message.replace(/\\n/g,'<br>')}</div>
        <div style="display:flex;gap:8px;justify-content:flex-end"></div>
      </div>
    </div>`;
  const btnWrap = modalRoot.querySelector('.modal > div:last-child');
  buttons.forEach(b=>{
    const btn = document.createElement('button'); btn.textContent = b.text;
    if(b.cls) btn.className = b.cls;
    btn.onclick = ()=> b.onClick();
    btnWrap.appendChild(btn);
  });
  modalRoot.classList.remove('hidden');
}
function hideModal(){ modalRoot.innerHTML=''; modalRoot.classList.add('hidden'); }

// helper to update counts
function updateCounts(){
  const g=App.game;
  cardsLeft.textContent = (g.playingDeck?g.playingDeck.length:0);
  promptsLeft.textContent = (g.promptDeck?g.promptDeck.length:0);
}

// update game area UI
function updateGameUI(){
  const g = App.game; if(!g) return;
  refreshPlayersUI(); rebuildActivePlayerSelect(); renderHand(); renderSubmissionStack(); updateCounts();
  currentPrompt.textContent = g.currentPrompt || 'No prompt yet';
}

// initial load: nothing
updateGameUI();

</script>
